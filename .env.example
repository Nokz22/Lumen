# Copia para .env e ajusta localmente. Nunca versionar o .env real.

# --- PostgreSQL ---
POSTGRES_DB=lumen
POSTGRES_USER=lumen
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=lumen
RABBITMQ_DEFAULT_PASS=changeme
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- Auth / crypto (backend has dev-only insecure defaults; ALWAYS override in prod) ---
JWT_SECRET=
ENCRYPTION_KEY=
CORS_ALLOWED_ORIGINS=http://localhost:5173
